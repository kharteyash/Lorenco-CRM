# Copy this file to ".env" and fill in your values, then restart the server.

# ---- Database (required) ----
# A Postgres connection string. Easiest free option: https://neon.tech
# Create a project, copy the connection string (it looks like the line below).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ---- Server ----
# Port to listen on (defaults to 3000).
# PORT=3000

# Set to "production" when deployed (enables secure cookies). Most hosts set this automatically.
# NODE_ENV=production

# TLS to the database is verified by default. Escape hatches if a provider needs them:
# DATABASE_CA_CERT=-----BEGIN CERTIFICATE-----...     # a custom CA (PEM) to trust
# DATABASE_SSL_NO_VERIFY=true                          # last resort — disables verification

# ---- Send as your Gmail (recommended) ----
# Powers the "Connect Gmail" button on the Automatic Emails page, so each user
# sends the weekly email from their OWN Gmail address via the Gmail API.
# Set up at https://console.cloud.google.com -> APIs & Services:
#   1) Create a project; enable the "Gmail API".
#   2) OAuth consent screen: External; add yourself as a test user.
#   3) Credentials -> OAuth client ID -> Web application.
#   4) Add an Authorized redirect URI that EXACTLY matches GOOGLE_REDIRECT_URI:
#        Local:      http://localhost:3000/api/google/callback
#        Production: https://YOUR-APP.onrender.com/api/google/callback
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# Optional: encrypt stored OAuth tokens at rest (any strong passphrase).
# TOKEN_ENC_KEY=some-long-random-string

# ---- Automatic emails via shared SMTP (optional fallback) ----
# Used only for users who HAVEN'T connected Gmail. The list + weekly schedule +
# template always work for editing regardless. Any provider works; Gmail with an
# App Password is the quickest:
#   1) Turn on 2-Step Verification on the Google account.
#   2) Create an App Password (Google Account -> Security -> App passwords).
#   3) SMTP_USER is the full address; SMTP_PASS is the 16-char app password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Your Name <you@yourdomain.com>

# Weekly sends fire from an internal hourly timer, but free hosts sleep when idle.
# For reliable weekly delivery, have an external cron hit this every few minutes:
#   GET https://YOUR-APP/api/cron/dispatch?key=CRON_SECRET   (e.g. cron-job.org)
# CRON_SECRET=set-a-long-random-string
